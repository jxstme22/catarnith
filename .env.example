# Copy to .env and fill local keys. This file holds ONLY the env vars the
# catarnith terminal reads. `.env` is gitignored — never commit it, and never
# paste a private key into chat, a command argument, or version control.

# === Required ===
# Primary RPC is derived from the Helius key. The optional fallback RPC is a
# distinct paid provider for extra broadcast/status reliability.
export HELIUS_API_KEY=your-helius-api-key-here
# Optional for live-buy/live-sell broadcast. If set, it must be distinct from
# the primary RPC and cannot be the public mainnet endpoint.
export CTARNITH_FALLBACK_RPC_URL=
# Jupiter sell fallback (LAST RESORT). Fires only after the local panic-sell
# + force-sell have both failed. Empty = fallback disabled (graceful).
# Requires an authenticated api.jup.ag key — the public lite endpoint
# excludes pre-graduation pump.fun mints.
export JUP_API_KEY=

# === Wallet (live) ===
# Pick one keypair source (path OR base58). When CTARNITH_WALLET_KEYPAIR_BASE58
# is set, it wins and no keypair file is required. The base58 form is a
# secret exported by Phantom, Solflare, `solana-keygen pubkey ASK`, etc.
# Keep the file owner-only.
export CTARNITH_WALLET_KEYPAIR_PATH=$HOME/.config/solana/catarnith-live-canary.json
# export CTARNITH_WALLET_KEYPAIR_BASE58=5xxx...64chars
export CTARNITH_LIVE_MAX_BALANCE_SOL=0.05
export CTARNITH_LIVE_CONFIG=config.toml

# === Core trading (editable in Settings and Auto Bot Setup) ===
export CTARNITH_LIVE_BASE_BUY_SOL=0.013025001
export CTARNITH_LIVE_MAX_SLIPPAGE_BPS=1500
# Optional hard freshness override. Config default rejects create events more
# than 2 slots behind the current processed slot.
# export CTARNITH_LIVE_MAX_CREATE_EVENT_SLOT_LAG=2
export CTARNITH_LIVE_MAX_HOLD_SECONDS=1

# === Advanced live setup (editable in Settings advanced) ===
export CTARNITH_LIVE_ENABLE_LIVE_TRADING=false
export CTARNITH_LIVE_REQUIRE_MANUAL_LIVE_UNLOCK=true
# Normal sell slippage (15%). Decoupled from buy; force-sell uses a wider floor.
export CTARNITH_LIVE_SELL_SLIPPAGE_BPS=1500
export CTARNITH_LIVE_COMPUTE_UNIT_PRICE_MICROLAMPORTS=100000
export CTARNITH_LIVE_JITO_BLOCK_ENGINE_URL=https://singapore.mainnet.block-engine.jito.wtf/api/v1/transactions
export CTARNITH_LIVE_JITO_TIP_SOL=0.0001
export CTARNITH_LIVE_PRE_BROADCAST_SIMULATION=true
# Low-credit read path. Broadcast still uses primary+fallback; status/balance
# reads use primary first unless this is set to 1.
export CTARNITH_LIVE_PARALLEL_FALLBACK_READS=0
export CTARNITH_LIVE_CONFIRMATION_POLL_MS=200

# === Auto Bot setup ([1] in the picker) ===
# mayhem_only | non_mayhem_only | all_pumpfun. non_mayhem_only is strict:
# fresh Pump.fun create/create-v2 only, curve is_mayhem_mode=false required,
# and copied Mayhem buys are ignored.
export CTARNITH_MARKET=mayhem_only
# Auto Bot risk caps. These are editable from Auto Bot Setup advanced.
export CTARNITH_LIVE_MAX_OPEN_POSITIONS=3
export CTARNITH_LIVE_MAX_BUYS_PER_MINT=5
export CTARNITH_LIVE_MAX_TOTAL_SOL_PER_MINT=0.1
export CTARNITH_LIVE_MAX_TOTAL_OPEN_SOL=0.3
export CTARNITH_LIVE_MAX_DAILY_LOSS_SOL=0.5
# Copy trade follows a source wallet through the normal bot market/risk/execution
# pipeline. Disabled by default.
export CTARNITH_LIVE_COPY_TRADE_ENABLED=false
export CTARNITH_LIVE_COPY_TRADE_WALLET=
export CTARNITH_LIVE_COPY_TRADE_SIZING=fixed
export CTARNITH_LIVE_COPY_TRADE_SCALE_BPS=10000
export CTARNITH_LIVE_COPY_TRADE_MAX_BUY_SOL=0.013025001
export CTARNITH_LIVE_COPY_TRADE_BUY_POLICY=first_only
export CTARNITH_LIVE_COPY_TRADE_MAX_BUYS_PER_MINT=1
export CTARNITH_LIVE_COPY_TRADE_MIN_SOURCE_BUY_SOL=0
export CTARNITH_LIVE_COPY_TRADE_MAX_HOLD_SECONDS=180
export CTARNITH_LIVE_COPY_TRADE_TAKE_PROFIT_BPS=8000
export CTARNITH_LIVE_COPY_TRADE_TAKE_PROFIT_SELL_BPS=10000
export CTARNITH_LIVE_COPY_TRADE_STOP_LOSS_BPS=3500
export CTARNITH_LIVE_COPY_TRADE_FOLLOW_SELLS=true
export CTARNITH_LIVE_BOT_KEEP_ALIVE=true
# Optional extra credit savers. Faster/cheaper, but less immediately certain.
# export CTARNITH_LIVE_WAIT_FOR_BUY_CONFIRMATION=false
# export CTARNITH_LIVE_SKIP_POST_TRADE_BALANCES=1

# === Optional terminal tuning ===
# Optional pin for SOL/USD price in the scan TUI. Skips the CoinGecko fetch
# on startup. Set to 0 or leave commented to fall back to CoinGecko with a
# 3s timeout, then to 200.0 if both fail.
# export CTARNITH_SCAN_SOL_PRICE_USD=205.42

# Force the scan TUI to skip the mode picker (equivalent to running
# `catarnith scan`). Useful for cronjobs or wrappers that always want trade mode.
# export CTARNITH_SCAN_SKIP_PICKER=1

# Panic-sell (TUI + shell `panic-sell <MINT>`)
# export CTARNITH_LIVE_PANIC_SEND_TIMEOUT_MS=350
# export CTARNITH_LIVE_PANIC_BALANCE_TIMEOUT_MS=500

# Optional Jito tip for panic-sell (recommended)
# export CTARNITH_LIVE_JITO_BLOCK_ENGINE_URL=https://amsterdam.mainnet.block-engine.jito.wtf
# export CTARNITH_LIVE_JITO_TIP_ACCOUNT=96gYZGLnJYVFmbjzopPSU6QiEV5fGqZNyNyeNmCz9L7
# export CTARNITH_LIVE_JITO_TIP_SOL=0.00001
